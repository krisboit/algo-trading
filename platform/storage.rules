rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Strategy .ex5 files — authenticated read/write
    match /strategies/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
